{
  "name": "s3-desktop-client",
  "version": "0.3.0",
  "description": "Desktop uploader/downloader for Amazon S3 (and compatible endpoints) with resume support",
  "main": "src/main.js",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "dev": "node scripts/start-electron.js",
    "test": "node --test --test-concurrency=1 --test-isolation=none",
    "postinstall": "electron-builder install-app-deps",
    "icon:build": "powershell -ExecutionPolicy Bypass -File scripts/generate-icon.ps1 && node scripts/build-icon.js",
    "pack": "electron-builder --dir",
    "build": "electron-builder"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.515.0",
    "basic-ftp": "^6.0.1",
    "keytar": "^7.9.0"
  },
  "overrides": {
    "fast-xml-parser": "^5.6.0"
  },
  "devDependencies": {
    "electron": "41.1.1",
    "electron-builder": "26.8.2",
    "png-to-ico": "^3.0.1"
  },
  "author": "S3 Desktop Client",
  "build": {
    "appId": "com.example.s3client",
    "productName": "S3 Desktop Client",
    "files": [
      "src/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
